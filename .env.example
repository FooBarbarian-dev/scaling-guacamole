# Django Settings
DJANGO_ENV=development  # Options: development, production
SECRET_KEY=change-me-to-a-random-secret-key  # TODO: Generate with `python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"`
DEBUG=True

# Database
DATABASE_URL=postgres://myproject:myproject@localhost:5432/myproject

# Redis
REDIS_URL=redis://localhost:6379/0

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# AI Assistant (Django AI Assistant / LangChain)
AI_ASSISTANT_OPENAI_API_BASE=https://api.openai.com/v1  # TODO: Set to your vLLM URL if using vLLM
AI_ASSISTANT_OPENAI_API_KEY=  # TODO: Set your OpenAI or vLLM API key
AI_ASSISTANT_MODEL=gpt-4o  # TODO: Set your model name

# Temporal.io
TEMPORALIO_HOST=localhost:7233
TEMPORALIO_TASK_QUEUE=main-task-queue
ENABLE_TEMPORAL_POST_PROCESSING=False

# Email (development uses console backend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
