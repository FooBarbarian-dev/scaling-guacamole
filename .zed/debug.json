{
    "configurations": [
        {
            "label": "Django: Runserver",
            "adapter": "debugpy",
            "program": "src/myproject/manage.py",
            "args": ["runserver", "0.0.0.0:8000"],
            "env": {
                "DJANGO_ENV": "development"
            }
        },
        {
            "label": "Django: Test Current File",
            "adapter": "debugpy",
            "module": "pytest",
            "args": ["${file}", "-v"],
            "env": {
                "DJANGO_ENV": "development"
            }
        },
        {
            "label": "Django: Attach to Docker",
            "adapter": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            }
        }
    ]
}
